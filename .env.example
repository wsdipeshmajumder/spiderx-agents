# Gemini API key with access to the Live API (generativelanguage.googleapis.com).
# In Dipesh's GCP this is `ipi-gemini-api-key` — copy its value here.
GEMINI_API_KEY=

# Optional: which Live model to open the session on. Fallbacks are tried
# automatically if this one isn't available to your key.
# Known candidates (the bridge auto-falls-back through this list):
#   gemini-2.5-flash-native-audio-latest
#   gemini-2.5-flash-native-audio-preview-12-2025
#   gemini-2.5-flash-native-audio-preview-09-2025
#   gemini-3.1-flash-live-preview
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest

LOG_LEVEL=INFO

# ─── Email delivery ────────────────────────────────────────────────────
# Provider for invite + post-call report emails:
#   EMAIL_PROVIDER=gmail     + EMAIL_USER + EMAIL_PWD (Gmail App Password)
#   EMAIL_PROVIDER=postmark  + POSTMARK_TOKEN
#   EMAIL_PROVIDER=resend    + RESEND_API_KEY
# Unset → emails are only logged. For Gmail, generate an App Password at
# https://myaccount.google.com/apppasswords (requires 2FA on the account).
EMAIL_PROVIDER=
EMAIL_USER=
EMAIL_PWD=
EMAIL_FROM=

# Where every persisted call's HTML post-call report is CC'd (in
# addition to per-agent owner emails). Set blank to disable.
REPORT_EMAIL_TO=

# ─── Telephony — Plivo / Twilio / Exotel auto-setup (Build 251) ───────
# Public HTTPS hostname for the carrier's Answer / Hangup / Fallback URLs
# and the audio WebSocket. Use ngrok / Cloudflare Tunnel locally, your
# Railway public domain in prod. Bare host or full URL; we adapt the
# scheme. Example: PUBLIC_HOST=agents.spiderx.ai
PUBLIC_HOST=
# Fernet key for encrypting carrier Auth Tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Comma-separated for rotation (new key first; MultiFernet decrypts with any).
# If unset, carrier creds are stored in plaintext — fine for local dev,
# never acceptable in prod. backend/telephony/secrets.py warns at boot.
TELEPHONY_CRED_KEY=

# ─── Firebase Web auth ─────────────────────────────────────────────────
# Web API key for the spiderx-ai-agents Firebase project. Injected into
# index.html at render time as window.__FIREBASE_API_KEY so it's not
# baked into the JS bundle. NOT a cryptographic secret — Firebase
# relies on Authorized Domains for security — but keeping it out of
# git lets staging/prod swap projects without code changes.
# Get yours: Firebase console → Project settings → General → Your apps
# → SDK setup and configuration → Config object → apiKey.
FIREBASE_API_KEY=
